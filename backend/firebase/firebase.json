{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json",
    "predeploy": [
      "npm --prefix ../.. run firebase:predeploy:firestore"
    ]
  },
  "storage": {
    "rules": "storage.rules",
    "predeploy": [
      "npm --prefix ../.. run firebase:predeploy:storage"
    ]
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix ../.. run firebase:predeploy:functions"
    ]
  },
  "emulators": {
    "firestore": {
      "host": "127.0.0.1",
      "port": 8080
    },
    "storage": {
      "host": "127.0.0.1",
      "port": 9199
    },
    "functions": {
      "host": "127.0.0.1",
      "port": 5001
    }
  }
}
