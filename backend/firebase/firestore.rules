rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(resourceData) {
      return signedIn() && resourceData.ownerId == request.auth.uid;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validListingStatus(status) {
      return status in ['draft', 'active', 'closed', 'cancelled'];
    }

    function validShipment(data) {
      return data.keys().hasOnly([
          'ownerId',
          'originCountry',
          'originCity',
          'destinationCountry',
          'destinationCity',
          'packageCategory',
          'packageDescription',
          'weightKg',
          'deliveryWindow',
          'rewardAmount',
          'rewardCurrency',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && data.ownerId is string
        && data.originCountry is string && data.originCountry.size() > 0 && data.originCountry.size() <= 80
        && data.originCity is string && data.originCity.size() > 0 && data.originCity.size() <= 120
        && data.destinationCountry is string && data.destinationCountry.size() > 0 && data.destinationCountry.size() <= 80
        && data.destinationCity is string && data.destinationCity.size() > 0 && data.destinationCity.size() <= 120
        && data.packageCategory is string && data.packageCategory.size() > 0 && data.packageCategory.size() <= 80
        && data.packageDescription is string && data.packageDescription.size() > 0 && data.packageDescription.size() <= 500
        && isNumber(data.weightKg) && data.weightKg > 0 && data.weightKg <= 100
        && data.deliveryWindow is string && data.deliveryWindow.size() > 0 && data.deliveryWindow.size() <= 120
        && isNumber(data.rewardAmount) && data.rewardAmount > 0 && data.rewardAmount <= 100000
        && data.rewardCurrency is string && data.rewardCurrency.size() == 3
        && validListingStatus(data.status);
    }

    function validTrip(data) {
      return data.keys().hasOnly([
          'ownerId',
          'originCountry',
          'originCity',
          'destinationCountry',
          'destinationCity',
          'departureDate',
          'arrivalDate',
          'availableCapacityKg',
          'notes',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && data.ownerId is string
        && data.originCountry is string && data.originCountry.size() > 0 && data.originCountry.size() <= 80
        && data.originCity is string && data.originCity.size() > 0 && data.originCity.size() <= 120
        && data.destinationCountry is string && data.destinationCountry.size() > 0 && data.destinationCountry.size() <= 80
        && data.destinationCity is string && data.destinationCity.size() > 0 && data.destinationCity.size() <= 120
        && data.departureDate is string && data.departureDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.arrivalDate is string && data.arrivalDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && isNumber(data.availableCapacityKg) && data.availableCapacityKg > 0 && data.availableCapacityKg <= 100
        && data.notes is string && data.notes.size() <= 500
        && validListingStatus(data.status);
    }

    function isBookingParticipant(data) {
      return signedIn()
        && (data.senderId == request.auth.uid || data.travelerId == request.auth.uid);
    }

    function validBookingStatus(status) {
      return status in [
        'pending',
        'accepted',
        'in_transit',
        'delivered',
        'completed',
        'cancelled',
        'declined',
        'expired'
      ];
    }

    function validBookingRequest(data) {
      return data.keys().hasOnly([
          'bookingId',
          'shipmentId',
          'tripId',
          'senderId',
          'travelerId',
          'message',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && data.bookingId is string
        && data.shipmentId is string
        && data.tripId is string
        && data.senderId is string
        && data.travelerId is string
        && data.senderId != data.travelerId
        && data.message is string && data.message.size() <= 500
        && data.status in ['pending', 'accepted', 'declined', 'cancelled', 'expired']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validBooking(data) {
      return data.keys().hasOnly([
          'bookingRequestId',
          'shipmentId',
          'tripId',
          'senderId',
          'travelerId',
          'status',
          'statusHistory',
          'createdAt',
          'updatedAt'
        ])
        && data.bookingRequestId is string
        && data.shipmentId is string
        && data.tripId is string
        && data.senderId is string
        && data.travelerId is string
        && data.senderId != data.travelerId
        && validBookingStatus(data.status)
        && data.statusHistory is list
        && data.statusHistory.size() > 0
        && data.statusHistory.size() <= 8
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validBookingListings(data) {
      let shipmentPath = /databases/$(database)/documents/shipments/$(data.shipmentId);
      let tripPath = /databases/$(database)/documents/trips/$(data.tripId);
      let shipment = get(shipmentPath).data;
      let trip = get(tripPath).data;
      return exists(shipmentPath)
        && exists(tripPath)
        && shipment.ownerId == data.senderId
        && trip.ownerId == data.travelerId
        && shipment.status == 'active'
        && trip.status == 'active'
        && shipment.originCountry == trip.originCountry
        && shipment.originCity == trip.originCity
        && shipment.destinationCountry == trip.destinationCountry
        && shipment.destinationCity == trip.destinationCity
        && shipment.weightKg <= trip.availableCapacityKg;
    }

    function validNotificationPreferences(data) {
      return data.keys().hasOnly([
          'userId',
          'channels',
          'categories',
          'quietHours',
          'createdAt',
          'updatedAt'
        ])
        && data.userId is string
        && data.channels is map
        && data.channels.keys().hasOnly(['push', 'email', 'sms'])
        && data.channels.push is bool
        && data.channels.email == false
        && data.channels.sms == false
        && data.categories is map
        && data.categories.keys().hasOnly([
          'booking_requests',
          'booking_updates',
          'custody_updates',
          'delivery_updates',
          'general_announcements',
          'review_reminders',
          'trust_profile_alerts'
        ])
        && data.categories.booking_requests is bool
        && data.categories.booking_updates is bool
        && data.categories.custody_updates is bool
        && data.categories.delivery_updates is bool
        && data.categories.general_announcements is bool
        && data.categories.review_reminders is bool
        && data.categories.trust_profile_alerts is bool
        && (data.quietHours == null || (
          data.quietHours is map
          && data.quietHours.keys().hasOnly([
            'startLocalTime',
            'endLocalTime',
            'timeZone'
          ])
          && data.quietHours.startLocalTime is string
          && data.quietHours.startLocalTime.matches('^([01]\\d|2[0-3]):[0-5]\\d$')
          && data.quietHours.endLocalTime is string
          && data.quietHours.endLocalTime.matches('^([01]\\d|2[0-3]):[0-5]\\d$')
          && data.quietHours.startLocalTime != data.quietHours.endLocalTime
          && data.quietHours.timeZone is string
          && data.quietHours.timeZone.size() > 0
          && data.quietHours.timeZone.size() <= 100
        ))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validVerificationStatus(status) {
      return status in [
        'unverified',
        'draft',
        'submitted',
        'under_review',
        'verified',
        'rejected',
        'expired',
        'revoked'
      ];
    }

    function validIdentityDocument(document) {
      return document is map
        && document.keys().hasOnly([
          'id',
          'type',
          'label',
          'issuingCountryCode',
          'expiresAt',
          'storagePath',
          'uploadedAt'
        ])
        && document.id is string
        && document.id.size() > 0
        && document.id.size() <= 128
        && document.type in [
          'passport',
          'national_id',
          'drivers_license',
          'residence_permit',
          'other'
        ]
        && document.label is string
        && document.label.size() > 0
        && document.label.size() <= 120
        && (document.issuingCountryCode == null || (
          document.issuingCountryCode is string
          && document.issuingCountryCode.matches('^[A-Z]{2}$')
        ))
        && (document.expiresAt == null || document.expiresAt is timestamp)
        // Storage remains deny-all; clients cannot claim an upload exists.
        && document.storagePath == null
        && document.uploadedAt == null;
    }

    function validVerificationEvent(event) {
      return event is map
        && event.keys().hasOnly([
          'id',
          'verificationId',
          'actorId',
          'actorType',
          'fromStatus',
          'toStatus',
          'status',
          'reason',
          'createdAt'
        ])
        && event.id is string
        && event.id.size() > 0
        && event.id.size() <= 240
        && event.verificationId is string
        && event.verificationId.size() > 0
        && event.verificationId.size() <= 128
        && (event.actorId == null || (
          event.actorId is string
          && event.actorId.size() > 0
          && event.actorId.size() <= 128
        ))
        && event.actorType in ['user', 'system', 'reviewer']
        && validVerificationStatus(event.fromStatus)
        && validVerificationStatus(event.toStatus)
        && event.status == event.toStatus
        && (event.reason == null || (
          event.reason is string
          && event.reason.size() > 0
          && event.reason.size() <= 500
        ))
        && event.createdAt is timestamp;
    }

    function validIdentityDocuments(documents) {
      return documents is list
        && documents.size() <= 10
        && (documents.size() < 1 || validIdentityDocument(documents[0]))
        && (documents.size() < 2 || validIdentityDocument(documents[1]))
        && (documents.size() < 3 || validIdentityDocument(documents[2]))
        && (documents.size() < 4 || validIdentityDocument(documents[3]))
        && (documents.size() < 5 || validIdentityDocument(documents[4]))
        && (documents.size() < 6 || validIdentityDocument(documents[5]))
        && (documents.size() < 7 || validIdentityDocument(documents[6]))
        && (documents.size() < 8 || validIdentityDocument(documents[7]))
        && (documents.size() < 9 || validIdentityDocument(documents[8]))
        && (documents.size() < 10 || validIdentityDocument(documents[9]));
    }

    function validVerificationEvents(events) {
      return events is list
        && events.size() > 0
        && events.size() <= 12
        && validVerificationEvent(events[0])
        && (events.size() < 2 || validVerificationEvent(events[1]))
        && (events.size() < 3 || validVerificationEvent(events[2]))
        && (events.size() < 4 || validVerificationEvent(events[3]))
        && (events.size() < 5 || validVerificationEvent(events[4]))
        && (events.size() < 6 || validVerificationEvent(events[5]))
        && (events.size() < 7 || validVerificationEvent(events[6]))
        && (events.size() < 8 || validVerificationEvent(events[7]))
        && (events.size() < 9 || validVerificationEvent(events[8]))
        && (events.size() < 10 || validVerificationEvent(events[9]))
        && (events.size() < 11 || validVerificationEvent(events[10]))
        && (events.size() < 12 || validVerificationEvent(events[11]));
    }

    function validIdentityVerification(data) {
      return data.keys().hasOnly([
          'userId',
          'status',
          'level',
          'documents',
          'events',
          'submittedAt',
          'reviewedAt',
          'expiresAt',
          'rejectionReason',
          'revokedReason',
          'createdAt',
          'updatedAt'
        ])
        && data.userId is string
        && validVerificationStatus(data.status)
        && data.level in ['none', 'basic', 'identity_verified']
        && validIdentityDocuments(data.documents)
        && validVerificationEvents(data.events)
        && (data.submittedAt == null || data.submittedAt is timestamp)
        && (data.reviewedAt == null || data.reviewedAt is timestamp)
        && (data.expiresAt == null || data.expiresAt is timestamp)
        && (data.rejectionReason == null || (
          data.rejectionReason is string
          && data.rejectionReason.size() > 0
          && data.rejectionReason.size() <= 500
        ))
        && (data.revokedReason == null || (
          data.revokedReason is string
          && data.revokedReason.size() > 0
          && data.revokedReason.size() <= 500
        ))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function identityVerificationCoreUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reviewedAt == resource.data.reviewedAt
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.rejectionReason == resource.data.rejectionReason
        && request.resource.data.revokedReason == resource.data.revokedReason;
    }

    function validAppendedVerificationEvent() {
      let events = request.resource.data.events;
      let previous = resource.data.events;
      let last = events[events.size() - 1];
      return events.size() == previous.size() + 1
        && events[0] == previous[0]
        && (previous.size() < 2 || events[1] == previous[1])
        && (previous.size() < 3 || events[2] == previous[2])
        && (previous.size() < 4 || events[3] == previous[3])
        && (previous.size() < 5 || events[4] == previous[4])
        && (previous.size() < 6 || events[5] == previous[5])
        && (previous.size() < 7 || events[6] == previous[6])
        && (previous.size() < 8 || events[7] == previous[7])
        && (previous.size() < 9 || events[8] == previous[8])
        && (previous.size() < 10 || events[9] == previous[9])
        && (previous.size() < 11 || events[10] == previous[10])
        && validVerificationEvent(last)
        && last.actorId == request.auth.uid
        && last.verificationId == resource.data.userId
        && last.actorType == 'user'
        && last.fromStatus == 'draft'
        && last.toStatus == 'submitted'
        && last.status == 'submitted'
        && last.reason == null
        && last.createdAt == request.resource.data.submittedAt;
    }

    function validUserVerificationUpdate() {
      return (
          resource.data.status == 'draft'
          && request.resource.data.status == 'draft'
          && request.resource.data.level == 'basic'
          && request.resource.data.events == resource.data.events
          && request.resource.data.submittedAt == null
          && validIdentityDocuments(request.resource.data.documents)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'documents',
            'updatedAt'
          ])
        ) || (
          resource.data.status == 'draft'
          && request.resource.data.status == 'submitted'
          && request.resource.data.level == 'basic'
          && request.resource.data.documents == resource.data.documents
          && request.resource.data.submittedAt is timestamp
          && request.resource.data.submittedAt <= request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'events',
            'submittedAt',
            'updatedAt'
          ])
          && validAppendedVerificationEvent()
        );
    }

    function bookingCoreUnchanged() {
      return request.resource.data.bookingRequestId == resource.data.bookingRequestId
        && request.resource.data.shipmentId == resource.data.shipmentId
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.travelerId == resource.data.travelerId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validBookingTransition() {
      return (
          resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'declined']
          && request.auth.uid == resource.data.travelerId
        ) || (
          resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled'
          && request.auth.uid == resource.data.senderId
        ) || (
          resource.data.status == 'accepted'
          && request.resource.data.status == 'in_transit'
          && request.auth.uid == resource.data.travelerId
        ) || (
          resource.data.status == 'in_transit'
          && request.resource.data.status == 'delivered'
          && request.auth.uid == resource.data.travelerId
        ) || (
          resource.data.status == 'delivered'
          && request.resource.data.status == 'completed'
          && request.auth.uid == resource.data.senderId
        );
    }

    function validAppendedBookingHistory() {
      let history = request.resource.data.statusHistory;
      let last = history[history.size() - 1];
      return history.size() == resource.data.statusHistory.size() + 1
        && history[0] == resource.data.statusHistory[0]
        && (resource.data.statusHistory.size() < 2
          || history[1] == resource.data.statusHistory[1])
        && (resource.data.statusHistory.size() < 3
          || history[2] == resource.data.statusHistory[2])
        && (resource.data.statusHistory.size() < 4
          || history[3] == resource.data.statusHistory[3])
        && (resource.data.statusHistory.size() < 5
          || history[4] == resource.data.statusHistory[4])
        && (resource.data.statusHistory.size() < 6
          || history[5] == resource.data.statusHistory[5])
        && (resource.data.statusHistory.size() < 7
          || history[6] == resource.data.statusHistory[6])
        && last.status == request.resource.data.status
        && last.changedBy == request.auth.uid
        && last.changedAt is timestamp;
    }

    function bookingRequestCoreUnchanged() {
      return request.resource.data.bookingId == resource.data.bookingId
        && request.resource.data.shipmentId == resource.data.shipmentId
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.travelerId == resource.data.travelerId
        && request.resource.data.message == resource.data.message
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validBookingRequestTransition() {
      return resource.data.status == 'pending'
        && (
          (request.resource.data.status in ['accepted', 'declined']
            && request.auth.uid == resource.data.travelerId)
          || (request.resource.data.status == 'cancelled'
            && request.auth.uid == resource.data.senderId)
        );
    }

    function linkedBookingMatchesRequest(requestId, data) {
      let booking = getAfter(
        /databases/$(database)/documents/bookings/$(data.bookingId)
      ).data;
      return booking.bookingRequestId == requestId
        && booking.shipmentId == data.shipmentId
        && booking.tripId == data.tripId
        && booking.senderId == data.senderId
        && booking.travelerId == data.travelerId
        && booking.status == data.status;
    }

    function linkedRequestMatchesBooking(bookingId, data) {
      let bookingRequest = getAfter(
        /databases/$(database)/documents/bookingRequests/$(data.bookingRequestId)
      ).data;
      return bookingRequest.bookingId == bookingId
        && bookingRequest.shipmentId == data.shipmentId
        && bookingRequest.tripId == data.tripId
        && bookingRequest.senderId == data.senderId
        && bookingRequest.travelerId == data.travelerId
        && bookingRequest.status == data.status;
    }

    function custodyEventExists(bookingId, eventType) {
      return exists(
        /databases/$(database)/documents/custodyEvents/$(bookingId + '__' + eventType)
      );
    }

    function validCustodySequence(data) {
      return data.eventType == 'shipment_created'
        || (data.eventType == 'traveler_accepted'
          && custodyEventExists(data.bookingId, 'shipment_created'))
        || (data.eventType == 'pickup_confirmed'
          && custodyEventExists(data.bookingId, 'traveler_accepted'))
        || (data.eventType == 'airport_departure'
          && custodyEventExists(data.bookingId, 'pickup_confirmed'))
        || (data.eventType == 'airport_arrival'
          && custodyEventExists(data.bookingId, 'airport_departure'))
        || (data.eventType == 'delivery_confirmed'
          && custodyEventExists(data.bookingId, 'pickup_confirmed'))
        || (data.eventType == 'completed'
          && custodyEventExists(data.bookingId, 'delivery_confirmed'));
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && request.auth.uid == userId
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    match /profiles/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.trustScore == null;
      allow update: if signedIn()
        && request.auth.uid == userId
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.trustScore == resource.data.trustScore;
      allow delete: if false;
    }

    match /shipments/{shipmentId} {
      allow read: if signedIn() && (owns(resource.data) || resource.data.status == 'active');
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validShipment(request.resource.data);
      allow update: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && validShipment(request.resource.data);
      allow delete: if false;
    }

    match /trips/{tripId} {
      allow read: if signedIn() && (owns(resource.data) || resource.data.status == 'active');
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validTrip(request.resource.data);
      allow update: if owns(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && validTrip(request.resource.data);
      allow delete: if false;
    }

    match /bookingRequests/{requestId} {
      allow read: if isBookingParticipant(resource.data);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validBookingRequest(request.resource.data)
        && validBookingListings(request.resource.data)
        && linkedBookingMatchesRequest(requestId, request.resource.data);
      allow update: if isBookingParticipant(resource.data)
        && bookingRequestCoreUnchanged()
        && validBookingRequest(request.resource.data)
        && validBookingRequestTransition()
        && request.resource.data.updatedAt == request.time
        && getAfter(
          /databases/$(database)/documents/bookings/$(resource.data.bookingId)
        ).data.status == request.resource.data.status;
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isBookingParticipant(resource.data);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.status == 'pending'
        && request.resource.data.statusHistory.size() == 1
        && request.resource.data.statusHistory[0].status == 'pending'
        && request.resource.data.statusHistory[0].changedBy == request.auth.uid
        && request.resource.data.statusHistory[0].changedAt is timestamp
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validBooking(request.resource.data)
        && validBookingListings(request.resource.data)
        && linkedRequestMatchesBooking(bookingId, request.resource.data);
      allow update: if isBookingParticipant(resource.data)
        && bookingCoreUnchanged()
        && validBooking(request.resource.data)
        && validBookingTransition()
        && validAppendedBookingHistory()
        && (resource.data.status != 'pending'
          || getAfter(
            /databases/$(database)/documents/bookingRequests/$(resource.data.bookingRequestId)
          ).data.status == request.resource.data.status)
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /custodyEvents/{eventId} {
      allow read: if isBookingParticipant(
        get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data
      );
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'bookingId',
          'shipmentId',
          'eventType',
          'performedBy',
          'location',
          'note',
          'metadata',
          'timestamp'
        ])
        && request.resource.data.bookingId is string
        && request.resource.data.bookingId.size() > 0
        && request.resource.data.bookingId.size() <= 128
        && request.resource.data.shipmentId is string
        && request.resource.data.shipmentId.size() > 0
        && request.resource.data.shipmentId.size() <= 128
        && request.resource.data.eventType in [
          'shipment_created',
          'traveler_accepted',
          'pickup_confirmed',
          'airport_departure',
          'airport_arrival',
          'delivery_confirmed',
          'completed'
        ]
        && request.resource.data.performedBy == request.auth.uid
        && (request.resource.data.location == null
          || (request.resource.data.location is string
            && request.resource.data.location.size() <= 160))
        && (request.resource.data.note == null
          || (request.resource.data.note is string
            && request.resource.data.note.size() <= 500))
        && request.resource.data.metadata is map
        && request.resource.data.metadata.keys().hasOnly(['bookingStatus'])
        && validBookingStatus(request.resource.data.metadata.bookingStatus)
        && request.resource.data.timestamp == request.time
        && eventId == request.resource.data.bookingId + '__' + request.resource.data.eventType
        && isBookingParticipant(
          getAfter(
            /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
          ).data
        )
        && request.resource.data.shipmentId == getAfter(
          /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
        ).data.shipmentId
        && request.resource.data.metadata.bookingStatus == getAfter(
          /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
        ).data.status
        && validCustodySequence(request.resource.data)
        && (
          (request.resource.data.eventType == 'shipment_created'
            && request.auth.uid == getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.senderId
            && getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.status == 'pending')
          || (request.resource.data.eventType == 'traveler_accepted'
            && request.auth.uid == getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.travelerId
            && getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.status == 'accepted')
          || (request.resource.data.eventType in ['pickup_confirmed', 'airport_departure', 'airport_arrival']
            && request.auth.uid == getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.travelerId
            && getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.status == 'in_transit')
          || (request.resource.data.eventType == 'delivery_confirmed'
            && request.auth.uid == getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.travelerId
            && getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.status == 'delivered')
          || (request.resource.data.eventType == 'completed'
            && request.auth.uid == getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.senderId
            && getAfter(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.status == 'completed')
        );
      allow update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'bookingId',
          'reviewerId',
          'subjectId',
          'direction',
          'rating',
          'comment',
          'createdAt',
          'updatedAt'
        ])
        && reviewId == request.resource.data.bookingId
          + '__' + request.resource.data.reviewerId
          + '__' + request.resource.data.subjectId
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerId != request.resource.data.subjectId
        && request.resource.data.direction in [
          'sender_reviews_traveler',
          'traveler_reviews_sender'
        ]
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 1000
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && get(
          /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
        ).data.status == 'completed'
        && (
          (request.resource.data.reviewerId == get(
            /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
          ).data.senderId
            && request.resource.data.subjectId == get(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.travelerId
            && request.resource.data.direction == 'sender_reviews_traveler')
          || (request.resource.data.reviewerId == get(
            /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
          ).data.travelerId
            && request.resource.data.subjectId == get(
              /databases/$(database)/documents/bookings/$(request.resource.data.bookingId)
            ).data.senderId
            && request.resource.data.direction == 'traveler_reviews_sender')
        );
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'userId',
          'title',
          'body',
          'type',
          'relatedEntityType',
          'relatedId',
          'status',
          'readAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 500
        && request.resource.data.status == 'unread'
        && request.resource.data.readAt == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && (
          (request.resource.data.relatedEntityType == 'booking'
            && request.resource.data.relatedId is string
            && (
              (request.resource.data.type == 'booking.requested'
                && request.auth.uid == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.senderId
                && request.resource.data.userId == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.travelerId
                && get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.status == 'pending')
              || (((request.resource.data.type == 'booking.accepted'
                    && get(
                      /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                    ).data.status == 'accepted')
                  || (request.resource.data.type == 'booking.declined'
                    && get(
                      /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                    ).data.status == 'declined'))
                && request.auth.uid == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.travelerId
                && request.resource.data.userId == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.senderId
                )
              || (request.resource.data.type == 'booking.cancelled'
                && request.auth.uid == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.senderId
                && request.resource.data.userId == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.travelerId
                && get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.status == 'cancelled')
              || (request.resource.data.type == 'shipment.completed'
                && request.auth.uid == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.senderId
                && request.resource.data.userId == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.travelerId
                && get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.status == 'completed')
              || (((request.resource.data.type == 'package.picked_up'
                    && get(
                      /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                    ).data.status == 'in_transit')
                  || (request.resource.data.type == 'package.delivered'
                    && get(
                      /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                    ).data.status == 'delivered'))
                && request.auth.uid == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.travelerId
                && request.resource.data.userId == get(
                  /databases/$(database)/documents/bookings/$(request.resource.data.relatedId)
                ).data.senderId
                )
            ))
          || (request.resource.data.relatedEntityType == 'review'
            && request.resource.data.type == 'review.submitted'
            && request.auth.uid == get(
              /databases/$(database)/documents/reviews/$(request.resource.data.relatedId)
            ).data.reviewerId
            && request.resource.data.userId == get(
              /databases/$(database)/documents/reviews/$(request.resource.data.relatedId)
            ).data.subjectId)
        );
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'readAt',
          'updatedAt'
        ])
        && resource.data.status == 'unread'
        && request.resource.data.status == 'read'
        && request.resource.data.readAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /notificationPreferences/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validNotificationPreferences(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid == userId
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && validNotificationPreferences(request.resource.data);
      allow delete: if false;
    }

    match /identityVerifications/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'draft'
        && request.resource.data.level == 'basic'
        && request.resource.data.documents.size() == 0
        && request.resource.data.events.size() == 1
        && request.resource.data.events[0].actorId == request.auth.uid
        && request.resource.data.events[0].verificationId == request.auth.uid
        && request.resource.data.events[0].actorType == 'user'
        && request.resource.data.events[0].fromStatus == 'unverified'
        && request.resource.data.events[0].toStatus == 'draft'
        && request.resource.data.events[0].status == 'draft'
        && request.resource.data.events[0].reason == null
        && request.resource.data.events[0].createdAt <= request.time
        && request.resource.data.submittedAt == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.expiresAt == null
        && request.resource.data.rejectionReason == null
        && request.resource.data.revokedReason == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validIdentityVerification(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid == userId
        && resource.data.userId == request.auth.uid
        && identityVerificationCoreUnchanged()
        && validUserVerificationUpdate()
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /trustScores/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
